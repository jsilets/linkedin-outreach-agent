# --- Database -------------------------------------------------------------
# Postgres connection string used by drizzle-kit and the runtime.
DATABASE_URL=postgres://user:password@localhost:5432/loa

# --- LLM provider (OPTIONAL) ----------------------------------------------
# The internal LLM is optional. In the primary mode an external agent (Claude
# Code / Codex) drives this framework over MCP and supplies the intelligence, so
# NO key is needed. The API path below is only a fallback for autonomous runs.
#
# Selection precedence: OPENROUTER_API_KEY -> OpenRouter, else ANTHROPIC_API_KEY
# -> Claude, else the offline deterministic Fake provider. With no key set the
# system still boots and runs (Fake).

# OpenRouter (first-class option for the autonomous fallback path). Uses the
# OpenAI-compatible HTTP API; no SDK dependency.
OPENROUTER_API_KEY=
# Model id in vendor/model form. Defaults to anthropic/claude-fable-5.
OPENROUTER_MODEL=anthropic/claude-fable-5
# Optional attribution headers (sent only when set): HTTP-Referer and X-Title.
OPENROUTER_SITE_URL=
OPENROUTER_APP_TITLE=

# Anthropic (used only when OPENROUTER_API_KEY is unset).
ANTHROPIC_API_KEY=

# --- Control-plane MCP server ---------------------------------------------
# Port the @loa/mcp server listens on.
MCP_PORT=8080

# --- Cookie vault ---------------------------------------------------------
# Symmetric key used to encrypt per-account session cookies at rest.
# Generate with: openssl rand -base64 32
COOKIE_VAULT_KEY=

# --- Egress proxies -------------------------------------------------------
# The sticky, per-account exit IP. Required for a real account: the first-login
# IP becomes the account's trusted baseline, so a real account must always run
# behind its own residential/ISP-static proxy. See infra/PROXY.md.
PROXY_URL=
PROXY_USERNAME=
PROXY_PASSWORD=
# Geo coherence for the proxy exit. Set EITHER a known city (resolved to a
# timezone/locale/geolocation) or the four explicit values. Known cities:
# new_york, los_angeles, chicago, dallas, miami, london, amsterdam, frankfurt,
# toronto.
PROXY_CITY=
# Explicit overrides (win over PROXY_CITY when set):
PROXY_TIMEZONE=
PROXY_LOCALE=
PROXY_LAT=
PROXY_LNG=

# --- Executor -------------------------------------------------------------
# 'fake' (default) never touches a browser; 'real' drives live patchright
# Chromium via the account-runner and needs a seeded session per account.
LOA_EXECUTOR=fake
# Persistent browser-profile root (one subdir per account) and encrypted
# cookie-vault root (one file per account). Defaults suit the container volume.
LOA_PROFILE_DIR=/data/profile
LOA_VAULT_DIR=/data/vault
# Escape hatch: allow the real executor to launch with NO proxy. Local checks
# against neutral pages only — never true for a real account.
LOA_ALLOW_NO_PROXY=false

# --- Runtime --------------------------------------------------------------
# node | development
NODE_ENV=development
# Log level: debug | info | warn | error
LOG_LEVEL=info
