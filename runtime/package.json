{
  "name": "@loa/runtime",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/main.js",
  "types": "./dist/main.d.ts",
  "exports": {
    ".": {
      "types": "./dist/compose.d.ts",
      "default": "./dist/compose.js"
    }
  },
  "scripts": {
    "build": "tsc -b",
