    "smoke": "node --import tsx src/smoke.ts"
  },
  "dependencies": {
    "@loa/account-runner": "*",
    "@loa/agent": "*",
    "@loa/mcp": "*",
    "@loa/orchestrator": "*",
    "@loa/safety": "*",
    "@loa/scheduler": "*",
    "@loa/shared": "*",
    "drizzle-orm": "^0.45.2"
  },
  "devDependencies": {
    "@types/node": "^24.10.0",
    "patchright": "^1.61.1"
  }
}
