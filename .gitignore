# dependencies
node_modules/

# build output
dist/
*.tsbuildinfo

# drizzle generated migrations output stays, but journal caches do not
infra/migrations/meta/_journal.tmp

# env & secrets
.env
.env.*
!.env.example

# logs
*.log
logs/

# browser session state / cookie vaults / profiles
profiles/
.cache/ms-playwright/
playwright-report/
test-results/

# os
.DS_Store

# local MCP client config (references tokens via env vars, no secrets)
.mcp.json

# local Claude Code tooling state (launch config, worktrees, locally installed
# skills) — but the repo's own dogfood-review skill is tracked. The carve-out is
# per-skill on purpose: .claude/skills/ also holds locally installed third-party
# skills that must stay untracked (and unlinted).
.claude/*
!.claude/skills/
.claude/skills/*
!.claude/skills/dogfood-review/
