{
  "name": "linkedin-outreach-agent",
  "version": "0.0.0",
  "private": true,
  "description": "Self-hosted, agent-driven LinkedIn outreach framework",
  "license": "Apache-2.0",
  "author": "Josh Silets",
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "workspaces": [
    "shared",
    "control-plane/mcp",
    "control-plane/orchestrator",
    "control-plane/scheduler",
    "control-plane/agent",
    "control-plane/safety",
    "account-runner",
    "runtime",
    "infra",
    "web"
  ],
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc -b",
    "clean": "tsc -b --clean",
    "test": "vitest run --passWithNoTests",
    "dev": "node --env-file-if-exists=.env --import tsx runtime/src/main.ts",
    "start": "node --env-file-if-exists=.env --import tsx runtime/src/main.ts",
    "smoke": "node --import tsx runtime/src/smoke.ts",
    "login": "node --env-file-if-exists=.env --import tsx runtime/src/login.ts",
    "leak-test": "node --env-file-if-exists=.env --import tsx runtime/src/tools/leak-test.ts",
    "search-shakeout": "node --env-file-if-exists=.env --import tsx runtime/src/tools/search-shakeout.ts",
    "act-shakeout": "node --env-file-if-exists=.env --import tsx runtime/src/tools/act-shakeout.ts",
    "link-account": "node --env-file-if-exists=.env --import tsx runtime/src/tools/link-account.ts",
    "source-to-list": "node --env-file-if-exists=.env --import tsx runtime/src/tools/source-to-list.ts",
    "selector-scan": "node --env-file-if-exists=.env --import tsx runtime/src/tools/selector-scan.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate"
  },
  "devDependencies": {
    "@types/node": "^24.10.0",
    "drizzle-kit": "^0.31.10",
    "tsx": "^4.23.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
